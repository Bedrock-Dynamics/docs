{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bedrock Dynamics",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#c6ac89",
    "light": "#8a6d42",
    "dark": "#c6ac89"
  },
  "background": {
    "color": {
      "dark": "#1a1816"
    }
  },
  "favicon": "/favicon.png",
  "banner": {
    "text": "Substrate is currently in closed beta.",
    "url": "https://bedrockdynamics.studio"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Substrate",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "substrate/introduction",
              "substrate/installation",
              "substrate/quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "substrate/features/simulation",
              "substrate/features/ai-assistant",
              "substrate/features/3d-viewer",
              "substrate/features/telemetry",
              "substrate/features/flight-review",
              "substrate/features/scene-authoring",
              "substrate/features/code-editor"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "substrate/guides/connect-robot",
              "substrate/guides/record-replay",
              "substrate/guides/custom-models"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "substrate/reference/ai-tools",
              "substrate/reference/flight-modes",
              "substrate/reference/coordinate-frames",
              "substrate/reference/docker-image",
              "substrate/reference/keyboard-shortcuts",
              "substrate/reference/supported-platforms",
              "substrate/reference/architecture"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "substrate/troubleshooting",
              "substrate/changelog",
              "substrate/roadmap"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://bedrockdynamics.studio",
          "icon": "globe"
        },
        {
          "anchor": "Coming Soon",
          "href": "https://bedrockdynamics.studio",
          "icon": "clock"
        },
        {
          "anchor": "Docker Hub",
          "href": "https://hub.docker.com/u/bedrockdynamics",
          "icon": "docker"
        },
        {
          "anchor": "Hugging Face",
          "href": "https://huggingface.co/bedrockdynamics",
          "icon": "face-smile"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "href": "https://discord.gg/bedrockdynamics"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Coming Soon",
      "href": "https://bedrockdynamics.studio"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bedrock-dynamics"
    }
  }
}
